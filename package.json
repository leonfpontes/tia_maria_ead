{
  "name": "tia_maria_ead",
  "version": "1.0.0",
  "description": "Projeto estático que apresenta a home institucional do Terreiro Tia Maria e Cabocla Jupira. O objetivo é disponibilizar uma base organizada segundo boas práticas do W3C, com documentação de apoio para evolução do site.",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "build:css": "npx --yes @tailwindcss/cli -i assets/css/tailwind.input.css -o assets/css/tailwind.css -m",
    "minify:css": "npx --yes clean-css-cli -o assets/css/main.css assets/css/main.css",
    "watch:css": "npx --yes @tailwindcss/cli -i assets/css/tailwind.input.css -o assets/css/tailwind.css -w",
    "build": "npm run build:css && npm run minify:css",
    "start": "npx --yes http-server -c-1 .",
    "setup:sqlite": "node scripts/setup-sqlite.js",
    "dev:local": "node server-local.js",
    "dev:api": "vercel dev"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/leonfpontes/tia_maria_ead.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/leonfpontes/tia_maria_ead/issues"
  },
  "homepage": "https://github.com/leonfpontes/tia_maria_ead#readme",
  "engines": {
    "node": "20.x"
  },
  "dependencies": {
    "@tailwindcss/cli": "^4.1.14",
    "autoprefixer": "^10.4.21",
    "bcryptjs": "^2.4.3",
    "dotenv": "^17.3.1",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.3",
    "postcss": "^8.5.6",
    "sql.js": "^1.12.0",
    "tailwindcss": "^4.1.14"
  },
  "devDependencies": {
    "vercel": "^50.25.6"
  }
}
